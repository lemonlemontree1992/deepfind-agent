# 本地调试环境 - 不提交到git

# 环境变量
local_config/.env.local
local_config/*.local

# 测试数据
test_data/*.csv
test_data/*.json
test_data/*.xlsx
test_data/*.txt

# 测试输出
test_outputs/reports/*
test_outputs/logs/*
test_outputs/*.html
test_outputs/*.pdf
test_outputs/*.md

# 临时文件
*.pyc
__pycache__/
.pytest_cache/
*.log
*.tmp

# IDE配置
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# 保留目录结构（但忽略内容）
!test_outputs/reports/.gitkeep
!test_outputs/logs/.gitkeep
!test_data/.gitkeep