# ========== 本地调试环境变量模板 ==========
# 复制此文件为 .env.local 并填入实际的API Key

# ========== DeepSeek API ==========
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ========== Tavily API ==========
TAVILY_API_KEY=tvly-your-tavily-api-key

# ========== Reddit API（免费）==========
# 申请地址: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=DeepFindAgent/1.0

# ========== OpenWeatherMap API（免费）==========
# 申请地址: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# ========== ExchangeRate API（免费）==========
# 申请地址: https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# ========== 本地调试开关 ==========
DEBUG_MODE=true
LOG_LEVEL=DEBUG
ENABLE_LOCAL_DATA=true

# ========== 服务器配置 ==========
BACKEND_HOST=localhost
BACKEND_PORT=8000
FRONTEND_HOST=localhost
FRONTEND_PORT=3000