# DeepFind Agent 环境配置

# ===========================================
# 必需配置
# ===========================================

# DeepSeek API Key（必需）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Tavily API Key（搜索必需）
# 获取地址：https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ===========================================
# 可选配置（使用默认值即可）
# ===========================================

# 搜索深度：shallow（浅度）或 deep（深度）
SEARCH_DEPTH=deep

# 报告语言：zh（中文）或 en（英文）
DEFAULT_LANGUAGE=zh

# 每次搜索返回的最大结果数
MAX_SEARCH_RESULTS=10